# Copy this file to  scripts/.deploy.env  (which is gitignored) and fill in your token.
# scripts/deploy.sh reads it; the token is never printed or committed.
#
# GitHub Personal Access Token:
#   - Classic PAT: scope "repo"
#   - Fine-grained PAT: repository access to this repo, "Contents: Read and write"
GITHUB_TOKEN=

# Optional overrides (defaults shown):
# GIT_REMOTE=origin
# GIT_BRANCH=main
